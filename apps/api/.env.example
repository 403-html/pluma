# Use 2137 when running alongside the Next.js app on port 3000
PORT=2137
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="postgresql://pluma:pluma@localhost:5432/pluma?schema=public"

# SMTP — docker compose auto-wires Mailpit (SMTP_HOST=mailpit, SMTP_PORT=1025).
# For standalone dev, point at localhost:1025 if running Mailpit separately, or leave blank to skip emails.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pluma.local
