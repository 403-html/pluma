# Use 2137 when running alongside the Next.js app on port 3000
PORT=2137
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="postgresql://pluma:pluma@localhost:5432/pluma?schema=public"

# Redis — BullMQ email queue. Start locally: docker run -p 6379:6379 redis:7-alpine
# Leave blank to send emails synchronously (no queue, no retry).
REDIS_URL=redis://localhost:6379

# SMTP settings (host, port, credentials, from address) are now stored in the
# database via Organization → Settings → SMTP Server in the UI. The SMTP_*
# environment variables have been removed. Use the UI to configure email delivery.
