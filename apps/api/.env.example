# Use 2137 when running alongside the Next.js app on port 3000
PORT=2137
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="postgresql://pluma:pluma@localhost:5432/pluma?schema=public"

# SMTP (optional — if SMTP_HOST is unset, welcome emails are skipped)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pluma.local
