# Use 2137 when running alongside the Next.js app on port 3000
PORT=2137
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="postgresql://pluma:pluma@localhost:5432/pluma?schema=public"

# Redis — BullMQ email queue. Start locally: docker run -p 6379:6379 redis:7-alpine
# Leave blank to send emails synchronously (no queue, no retry).
REDIS_URL=redis://localhost:6379

# SMTP — for actual mail delivery, run the Postfix relay via docker compose
# (docker compose up postfix) then use SMTP_HOST=localhost, SMTP_PORT=1587.
# Or point at any SMTP server. Leave SMTP_HOST blank to disable email entirely.
SMTP_HOST=localhost
SMTP_PORT=1587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pluma.local
